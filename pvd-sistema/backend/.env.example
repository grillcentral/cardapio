# ═══════════════════════════════════════════════════════════════════════════
# Configurações de Ambiente — Backend
# Copie para .env e preencha com valores reais. NUNCA commite o .env!
# ═══════════════════════════════════════════════════════════════════════════

# Servidor
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://lanche:lanche_dev@localhost:5432/lanche_pdv?schema=public"

# Redis (cache e filas)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="TROQUE_ISSO_POR_UM_SEGREDO_LONGO_E_ALEATORIO_EM_PRODUCAO_64_CHARS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS - URLs permitidas do frontend (separadas por vírgula)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="1 minute"
