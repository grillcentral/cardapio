{
  "name": "lanche-saas-backend",
  "version": "1.0.0",
  "description": "Backend SaaS multi-tenant para PDV de food service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker": "tsx watch src/workers/scheduler.ts",
    "worker:prod": "node dist/workers/scheduler.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fast-jwt": "^6.0.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.4",
    "prisma": "^5.22.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
