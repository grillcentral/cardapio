// ═══════════════════════════════════════════════════════════════════════════
// LANCHE PDV SaaS — Schema do Banco de Dados
// ═══════════════════════════════════════════════════════════════════════════
// Multi-tenant: todas as tabelas (exceto Tenant e User-super) têm tenantId
// ORM: Prisma + PostgreSQL
// Convenção: soft delete via deletedAt, audit via createdBy/updatedBy
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// MULTI-TENANCY & BILLING
// ═══════════════════════════════════════════════════════════════════════════

model Tenant {
  id              String      @id @default(cuid())
  slug            String      @unique // "burger-do-jailson"
  name            String      // "Lanche do Jailson"
  cnpj            String?     @unique
  email           String
  phone           String?
  plan            Plan        @default(TRIAL)
  planExpiresAt   DateTime?
  maxStores       Int         @default(1)
  maxUsers        Int         @default(5)
  status          TenantStatus @default(ACTIVE)
  settings        Json        @default("{}")  // customizações por cliente

  // Billing
  billingEmail    String?
  lastPaymentAt   DateTime?
  nextBillingAt   DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  stores          Store[]
  users           User[]
  auditLogs       AuditLog[]
  coupons         CouponCode[]

  @@index([status])
  @@index([slug])
  @@map("tenants")
}

model CouponCode {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  description String?
  type        String    // PERCENTAGE | FIXED
  value       Decimal   @db.Decimal(10,2)
  minOrder    Decimal   @default(0) @db.Decimal(10,2)
  maxUses     Int?
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("coupon_codes")
}

enum Plan {
  TRIAL          // 14 dias grátis
  STARTER        // 1 loja, 5 usuários, recursos básicos
  PRO            // 3 lojas, 20 usuários, tudo
  ENTERPRISE     // Ilimitado, suporte dedicado
}

enum TenantStatus {
  ACTIVE
  SUSPENDED      // Não paga mas não apaga
  CANCELLED
  TRIAL_EXPIRED
}

model Store {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String      // "Unidade Centro"
  address         String?
  phone           String?
  taxFee          Decimal     @default(0) @db.Decimal(10, 2) // taxa de entrega padrão
  serviceFee      Decimal     @default(0) @db.Decimal(5, 2)  // taxa de serviço (10%)

  openingHours    Json?       // horários por dia da semana
  isActive        Boolean     @default(true)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  users           User[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  cashSessions    CashSession[]
  customers       Customer[]
  deliverers      Deliverer[]
  printers        Printer[]

  @@index([tenantId])
  @@map("stores")
}

// ═══════════════════════════════════════════════════════════════════════════
// USUÁRIOS E AUTENTICAÇÃO
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id              String      @id @default(cuid())
  tenantId        String?     // null apenas para super admins
  tenant          Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId         String?
  store           Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)

  name            String
  email           String
  password        String      // bcrypt
  role            UserRole
  pin             String?     // PIN 4-6 dígitos para login rápido no PDV

  isActive        Boolean     @default(true)
  lastLoginAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Relações como ator
  ordersCreated   Order[]     @relation("OrderCreatedBy")
  cashSessions    CashSession[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN     // gerencia o SaaS todo (você)
  OWNER           // dono da lanchonete
  MANAGER         // gerente
  CASHIER         // caixa
  WAITER          // garçom
  KITCHEN         // cozinha
  DELIVERER       // entregador (mobile)
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  userAgent   String?
  ipAddress   String?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════
// CATÁLOGO (Categorias, Produtos, Combos, Adicionais)
// ═══════════════════════════════════════════════════════════════════════════

model Category {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name            String
  icon            String?     // emoji ou nome de ícone
  color           String?     // HEX
  displayOrder    Int         @default(0)
  isActive        Boolean     @default(true)

  // Para KDS: qual estação da cozinha prepara essa categoria
  kitchenStation  String?     // "grill", "cold", "bar", "fryer"

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  products        Product[]

  @@index([tenantId, storeId])
  @@map("categories")
}

model Product {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])

  sku             String?     // código do produto
  name            String
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  cost            Decimal?    @db.Decimal(10, 2) // custo de produção (CMV)
  imageUrl        String?

  // Controle de estoque
  trackStock      Boolean     @default(true)
  stock           Int         @default(0)
  minStock        Int         @default(0) // alerta

  // Visibilidade
  isActive        Boolean     @default(true)
  availableInDelivery Boolean @default(true)
  availableInStore    Boolean @default(true)

  prepTimeMinutes Int?        // tempo estimado de preparo
  displayOrder    Int         @default(0)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  orderItems      OrderItem[]
  modifierGroups  ProductModifierGroup[]
  comboItems      ComboItem[]
  priceHistory    ProductPriceHistory[]

  @@unique([tenantId, storeId, sku])
  @@index([tenantId, storeId])
  @@index([categoryId])
  @@map("products")
}

// Histórico de preço: essencial para não alterar valor de pedidos abertos
model ProductPriceHistory {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Decimal   @db.Decimal(10, 2)
  validFrom   DateTime  @default(now())
  changedBy   String

  @@index([productId, validFrom])
  @@map("product_price_history")
}

// Adicionais/Modificadores: ex: "Tamanho" (P, M, G), "Ponto da carne", "Extras"
model ModifierGroup {
  id              String      @id @default(cuid())
  tenantId        String
  name            String      // "Tamanho", "Adicional", "Ponto"
  isRequired      Boolean     @default(false)
  minSelections   Int         @default(0)
  maxSelections   Int         @default(1)

  modifiers       Modifier[]
  products        ProductModifierGroup[]

  @@index([tenantId])
  @@map("modifier_groups")
}

model Modifier {
  id              String        @id @default(cuid())
  groupId         String
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name            String        // "Grande", "Bacon", "Ao ponto"
  priceDelta      Decimal       @default(0) @db.Decimal(10, 2) // pode ser negativo
  displayOrder    Int           @default(0)
  isActive        Boolean       @default(true)

  orderItemMods   OrderItemModifier[]

  @@index([groupId])
  @@map("modifiers")
}

model ProductModifierGroup {
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId         String
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([productId, groupId])
  @@map("product_modifier_groups")
}

// Combos: agrupa vários produtos com preço promocional
model Combo {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  name            String
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  isActive        Boolean     @default(true)
  imageUrl        String?

  validFrom       DateTime?
  validUntil      DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           ComboItem[]

  @@index([tenantId, storeId])
  @@map("combos")
}

model ComboItem {
  id          String    @id @default(cuid())
  comboId     String
  combo       Combo     @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int       @default(1)

  @@map("combo_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// CLIENTES
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name            String
  phone           String?
  email           String?
  cpf             String?
  birthday        DateTime?
  notes           String?     // "Sempre pede sem cebola"

  // Stats agregados (atualizados via trigger ou job)
  totalOrders     Int         @default(0)
  totalSpent      Decimal     @default(0) @db.Decimal(12, 2)
  lastOrderAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  addresses       CustomerAddress[]
  orders          Order[]

  @@index([tenantId, storeId])
  @@index([phone])
  @@map("customers")
}

model CustomerAddress {
  id              String      @id @default(cuid())
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label           String?     // "Casa", "Trabalho"
  street          String
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?
  reference       String?     // "próximo à padaria"
  isDefault       Boolean     @default(false)

  // Taxa de entrega específica pra esse endereço
  deliveryFee     Decimal?    @db.Decimal(10, 2)

  createdAt       DateTime    @default(now())

  orders          Order[]

  @@index([customerId])
  @@map("customer_addresses")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTREGADORES
// ═══════════════════════════════════════════════════════════════════════════

model Deliverer {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name            String
  phone           String?
  document        String?     // CPF
  vehicle         String?     // "Moto Honda Biz 2020"
  plate           String?
  commissionType  CommissionType @default(FIXED)
  commissionValue Decimal     @default(0) @db.Decimal(10, 2) // R$ fixo ou % conforme o tipo

  isActive        Boolean     @default(true)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  deliveries      Delivery[]

  @@index([tenantId, storeId])
  @@map("deliverers")
}

enum CommissionType {
  FIXED       // R$ fixo por entrega
  PERCENTAGE  // % do valor do pedido
  PER_KM      // R$ por km (precisa integração futura)
}

// ═══════════════════════════════════════════════════════════════════════════
// PEDIDOS (Order = unidade central do sistema)
// ═══════════════════════════════════════════════════════════════════════════

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])

  // Número sequencial por loja (reseta todo dia) — para exibição fácil
  orderNumber     Int
  businessDate    DateTime    @db.Date // dia fiscal/operacional (madrugada conta como dia anterior)

  type            OrderType
  status          OrderStatus @default(OPEN)
  channel         OrderChannel @default(IN_STORE)

  // Identificação humana da comanda: "Mesa 5", "João", etc
  reference       String?

  // Relações com pessoas/recursos
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  addressId       String?
  address         CustomerAddress? @relation(fields: [addressId], references: [id])
  createdById     String
  createdBy       User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  cashSessionId   String?
  cashSession     CashSession? @relation(fields: [cashSessionId], references: [id])

  // Valores (calculados no backend - imutáveis)
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  discountReason  String?
  serviceFee      Decimal     @default(0) @db.Decimal(12, 2) // taxa de serviço
  deliveryFee     Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)

  notes           String?     // observações gerais
  kitchenNotes    String?     // observações específicas pra cozinha

  // Timestamps de workflow
  openedAt        DateTime    @default(now())
  sentToKitchenAt DateTime?
  readyAt         DateTime?
  closedAt        DateTime?
  cancelledAt     DateTime?
  cancelledReason String?
  cancelledById   String?

  items           OrderItem[]
  payments        Payment[]
  delivery        Delivery?
  statusHistory   OrderStatusHistory[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([tenantId, storeId, businessDate, orderNumber])
  @@index([tenantId, storeId, status])                     // open orders query
  @@index([tenantId, storeId, businessDate, status])       // dashboard reports
  @@index([businessDate])
  @@index([customerId])
  @@index([cashSessionId])
  @@index([createdById])
  @@map("orders")
}

enum OrderType {
  TABLE          // consumo no local (mesa)
  COUNTER        // balcão
  DELIVERY       // entrega
  TAKEOUT        // retirada
}

enum OrderStatus {
  OPEN           // comanda aberta, ainda adicionando itens
  SENT_KITCHEN   // enviado à cozinha
  PREPARING      // em preparo
  READY          // pronto para servir/sair
  DELIVERING     // saiu pra entrega (delivery)
  DELIVERED      // entregue (delivery)
  CLOSED         // pago e finalizado
  CANCELLED      // cancelado
}

enum OrderChannel {
  IN_STORE       // operador lançou manualmente
  IFOOD          // veio do iFood
  WHATSAPP       // veio do WhatsApp
  SELF_SERVICE   // cliente pediu pelo QR Code
  APP            // app próprio
}

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product     @relation(fields: [productId], references: [id])

  // Snapshot no momento do pedido (imutável mesmo se o produto mudar)
  productName     String
  unitPrice       Decimal     @db.Decimal(10, 2)
  quantity        Int
  subtotal        Decimal     @db.Decimal(12, 2) // unitPrice * qty + modifiers
  notes           String?     // "sem cebola, bem passado"

  status          OrderItemStatus @default(PENDING)
  kitchenStation  String?
  sentToKitchenAt DateTime?
  readyAt         DateTime?

  modifiers       OrderItemModifier[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orderId])
  @@index([orderId, status])  // KDS: busca itens pendentes por pedido
  @@index([productId])
  @@map("order_items")
}

enum OrderItemStatus {
  PENDING        // adicionado, ainda não foi pra cozinha
  SENT           // enviado pra cozinha
  PREPARING      // em preparo
  READY          // pronto
  DELIVERED      // entregue ao cliente
  CANCELLED      // cancelado (só pode antes de ir à cozinha)
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String
  modifier    Modifier  @relation(fields: [modifierId], references: [id])

  // Snapshot
  name        String
  priceDelta  Decimal   @db.Decimal(10, 2)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  changedBy   String
  changedAt   DateTime    @default(now())
  notes       String?

  @@index([orderId])
  @@map("order_status_history")
}

// ═══════════════════════════════════════════════════════════════════════════
// PAGAMENTOS (um pedido pode ter múltiplos pagamentos - conta dividida)
// ═══════════════════════════════════════════════════════════════════════════

model Payment {
  id              String      @id @default(cuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method          PaymentMethod
  amount          Decimal     @db.Decimal(12, 2)
  change          Decimal     @default(0) @db.Decimal(12, 2) // troco (pra dinheiro)
  received        Decimal?    @db.Decimal(12, 2) // valor recebido (pra dinheiro)

  // Para cartão/PIX
  transactionId   String?     // ID da maquininha
  authCode        String?
  nsu             String?
  cardBrand       String?     // Visa, Master, etc
  installments    Int?        @default(1)

  processedAt     DateTime    @default(now())
  processedBy     String

  @@index([orderId])
  @@map("payments")
}

enum PaymentMethod {
  CASH            // dinheiro
  PIX
  CREDIT_CARD
  DEBIT_CARD
  MEAL_VOUCHER    // VR/VA
  STORE_CREDIT    // fiado / crédito do cliente
  IFOOD_ONLINE    // pago no app
  OTHER
}

// ═══════════════════════════════════════════════════════════════════════════
// CAIXA (abertura/fechamento com conferência)
// ═══════════════════════════════════════════════════════════════════════════

model CashSession {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  userId          String
  user            User        @relation(fields: [userId], references: [id])

  businessDate    DateTime    @db.Date
  openingAmount   Decimal     @db.Decimal(12, 2)
  closingAmount   Decimal?    @db.Decimal(12, 2)
  expectedAmount  Decimal?    @db.Decimal(12, 2) // calculado
  difference      Decimal?    @db.Decimal(12, 2) // sobra/falta

  openedAt        DateTime    @default(now())
  closedAt        DateTime?

  notes           String?

  orders          Order[]
  movements       CashMovement[]

  @@index([tenantId, storeId, businessDate])
  @@map("cash_sessions")
}

model CashMovement {
  id              String      @id @default(cuid())
  sessionId       String
  session         CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type            CashMovementType
  amount          Decimal     @db.Decimal(12, 2)
  description     String
  createdAt       DateTime    @default(now())
  createdBy       String

  @@index([sessionId])
  @@map("cash_movements")
}

enum CashMovementType {
  OPENING         // fundo de caixa
  SALE            // venda (entrada)
  WITHDRAWAL      // sangria (saída)
  REINFORCEMENT   // suprimento (entrada extra)
  EXPENSE         // despesa paga do caixa
  CLOSING         // fechamento
}

// ═══════════════════════════════════════════════════════════════════════════
// ENTREGAS (tabela dedicada pra delivery, separada do Order)
// ═══════════════════════════════════════════════════════════════════════════

model Delivery {
  id              String      @id @default(cuid())
  orderId         String      @unique
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  delivererId     String?
  deliverer       Deliverer?  @relation(fields: [delivererId], references: [id])

  status          DeliveryStatus @default(WAITING)

  // Timestamps
  dispatchedAt    DateTime?   // saiu pra entrega
  deliveredAt     DateTime?   // entregue
  returnedAt      DateTime?   // voltou (erro na entrega)

  distanceKm      Decimal?    @db.Decimal(6, 2)
  estimatedMinutes Int?
  actualMinutes   Int?
  delivererFee    Decimal     @default(0) @db.Decimal(10, 2)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([delivererId])
  @@index([status])
  @@index([status, createdAt])  // delivery dashboard
  @@map("deliveries")
}

enum DeliveryStatus {
  WAITING         // aguardando preparo
  READY           // pronto pra sair
  DISPATCHED      // saiu
  DELIVERED       // entregue
  RETURNED        // voltou (endereço errado, cliente não atendeu, etc)
}

// ═══════════════════════════════════════════════════════════════════════════
// IMPRESSÃO
// ═══════════════════════════════════════════════════════════════════════════

model Printer {
  id              String      @id @default(cuid())
  tenantId        String
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name            String      // "Caixa", "Cozinha", "Bar"
  kind            PrinterKind
  interface       String      // "tcp://192.168.1.100:9100" ou "printer:COZINHA"
  brand           String      @default("EPSON") // EPSON, STAR, custom
  paperWidth      Int         @default(48)      // 48 para 80mm, 32 para 58mm

  kitchenStations String[]    // ["grill", "fryer"] - quais categorias imprimir aqui
  isActive        Boolean     @default(true)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId, storeId])
  @@map("printers")
}

enum PrinterKind {
  RECEIPT         // cupom do cliente
  KITCHEN         // comanda da cozinha
  BAR             // comanda do bar
  DELIVERY        // despacho de delivery
}

// ═══════════════════════════════════════════════════════════════════════════
// AUDITORIA
// ═══════════════════════════════════════════════════════════════════════════

model AuditLog {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  action          String      // "ORDER_CANCELLED", "PRICE_CHANGED", etc
  entityType      String      // "Order", "Product", etc
  entityId        String?

  oldValue        Json?
  newValue        Json?
  metadata        Json?       // IP, user agent, etc

  createdAt       DateTime    @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
